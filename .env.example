# ─────────────────────────────────────────────────────────────────────────────
# ESN Manager — Variables d'environnement
# Copier ce fichier en .env.local pour le développement
# NE JAMAIS commiter .env.local dans git
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Base de données (Neon PostgreSQL) ─────────────────────────────────────────
# Créer un projet sur https://neon.tech (gratuit)
# Copier la connection string "Pooled connection"
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Authentification (NextAuth v5) ────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com (gratuit : 3000 emails/mois)
# Ajouter votre domaine dans Resend → Settings → Domains
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=ESN Manager <noreply@votre-domaine.fr>

# ── Rate Limiting (optionnel — Upstash Redis) ─────────────────────────────────
# Créer une DB sur https://upstash.com (gratuit)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXX

# ── Stockage fichiers (optionnel — Vercel Blob) ───────────────────────────────
# Pour les justificatifs PDF uploadés par les consultants
# BLOB_READ_WRITE_TOKEN=vercel_blob_XXXXXXXXXXXX

# ── Vercel (CI/CD) ────────────────────────────────────────────────────────────
# VERCEL_TOKEN=XXXXXXXXXXXX
# VERCEL_ORG_ID=XXXXXXXXXXXX
# VERCEL_PROJECT_ID=XXXXXXXXXXXX

# ── Stockage justificatifs (Vercel Blob) ──────────────────────────────────────
# Activer dans Vercel → Storage → Create Blob store
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXX

# ── CRON Sécurité ─────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
# Ajouter aussi dans vercel.json la même valeur
CRON_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
